# ─── Build Mode ──────────────────────────────────────────────────────────────
# "export"     → static HTML/CSS/JS output in out/  (deploy to GCS or S3)
# "standalone" → minimal Node.js server (deploy to Cloud Run or ECS)
NEXT_OUTPUT=export

# ─── CDN / Asset Prefix ──────────────────────────────────────────────────────
# GCP example : https://storage.googleapis.com/your-bucket-name
# AWS example : https://d1234abcd.cloudfront.net
# Leave blank when running locally or when the server serves its own assets
NEXT_PUBLIC_ASSET_PREFIX=

# ─── Telemetry ───────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
